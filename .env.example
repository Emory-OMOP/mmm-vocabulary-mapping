# Copy to .env and fill in. Used by docker-compose.yml.  (`.env` is git-ignored.)

# Your Claude API key (used by the webapp to call the model).
ANTHROPIC_API_KEY=sk-ant-...

# A passkey you invent. The webapp gates POST /api/auth/login on it, and the
# pipeline logs in with it to get a token. Any string — just use the SAME value
# for OHDSI_AGENT_FASTAPI_PASSKEY when you run the pipeline. It is a local gate
# only (not an account, not your Anthropic key).
BETA_PASSKEY=choose-a-passkey

# JWT_SECRET=changeme-jwt-secret          # optional; signs the login tokens
# OHDSI_AGENT_MODEL=claude-opus-4-7        # model the winning run used

# ── Host paths to the data you built locally (see README "Data") ─────────────
# Absolute paths. Mounted read-only into the containers.
VOCAB_DUCKDB=/abs/path/to/omop_vocab.duckdb                       # OMOP vocabulary (main_vocab)
EMBEDDINGS_DB=/abs/path/to/concept_embeddings.duckdb             # SapBERT Standard index
NONSTD_EMBEDDINGS_DB=/abs/path/to/concept_embeddings_nonstandard.duckdb  # SapBERT non-standard index
